# ─────────────────────────────────────────────────────────────────────────────
# ClickTake Technologies — production env vars
#
# Copy this file to `.env.production` (gitignored) and fill in the values,
# OR set them directly in the Cloudflare / Vercel dashboards.
#
# Every variable below is consumed by code in `src/`. Lines starting with `#`
# are documentation; uncomment + fill the others.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Core app ────────────────────────────────────────────────────────────────
NODE_ENV=production

# Public Supabase URL + anon key (already in wrangler.toml [vars], re-listed
# here for Vercel — Vercel doesn't read wrangler.toml).
NEXT_PUBLIC_SUPABASE_URL=https://crejzifwpcnjqghlbbdf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_rKUt-lIGNXG6QO9i8dLViw_FE0PcXyD

# Cloudinary (public — used by the contact-form uploader)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dwioesu97
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=contact_uploads

# Cloudflare Turnstile (bot protection on public forms)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADpHuqrF417pgTBa
TURNSTILE_SECRET_KEY=                          # server-side — from Cloudflare dashboard

# ─── Database ────────────────────────────────────────────────────────────────
# Postgres connection string (Supabase / Neon / RDS / etc.)
DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require
DIRECT_URL=                                     # same as DATABASE_URL (Supabase direct, no pooler)

# ─── Auth ────────────────────────────────────────────────────────────────────
# NextAuth reads these automatically — do NOT rename.
NEXTAUTH_SECRET=                                # openssl rand -base64 32
NEXTAUTH_URL=https://clicktaketech.com          # canonical production URL

# Super-admin bootstrap (used once on first boot to seed the first admin user)
SUPERADMIN_EMAIL=admin@clicktaketech.com
SUPERADMIN_PASSWORD=                            # change after first login

# Provider credentials encryption key (used to encrypt stored API keys for
# SMTP / Cloudflare / etc. inside the admin panel). MUST be 64 hex chars.
PROVIDER_CREDENTIALS_ENCRYPTION_KEY=            # openssl rand -hex 32

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
MAIL_FROM=ClickTake <noreply@clicktaketech.com>
SMTP_FROM=ClickTake <noreply@clicktaketech.com> # alias — code accepts either

# Where contact-form leads + career applications are sent (defaults to
# leads@clicktaketech.com / careers@clicktaketech.com if unset).
LEADS_EMAIL=leads@clicktaketech.com
CAREERS_EMAIL=careers@clicktaketech.com
PROVIDER_ALERT_TO=alerts@clicktaketech.com

# ─── Cron ────────────────────────────────────────────────────────────────────
# Token required to call /api/cron/* endpoints (set in vercel.json + used by
# Cloudflare cron triggers). Must match the token in the URL.
CRON_SECRET=bc5897828779be9dac20963c

# ─── Cloudflare Worker only ──────────────────────────────────────────────────
# When set, the CF Worker proxies /api/* and /admin/* to this URL.
# Set this to the Vercel production URL after deploying to Vercel.
# (Set via: echo "https://clicktake.vercel.app" | bunx wrangler secret put BACKEND_URL)
BACKEND_URL=https://clicktake.vercel.app

# ─── Optional OAuth providers (uncomment + fill to enable) ───────────────────
# GITHUB_ID=
# GITHUB_SECRET=
# GOOGLE_ID=
# GOOGLE_SECRET=

# ─── Optional: provider debug logging ────────────────────────────────────────
# PROVIDER_DEBUG=true
