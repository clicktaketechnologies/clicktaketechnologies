generator client {
  provider = "prisma-client-js"
  // driverAdapters + queryCompiler are stable in Prisma 6.10+ — no preview flag needed.
  // Together they remove the 2.2MB WASM query engine from the bundle by
  // compiling Prisma queries in pure JS and routing SQL through @prisma/adapter-pg.
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Page {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  content         String   @default("")
  blocks          String   @default("[]")
  isPublished     Boolean  @default(false) @map("is_published")
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  canonicalUrl    String?  @map("canonical_url")
  ogImageUrl      String?  @map("og_image_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("pages")
}

model CmsMedia {
  id         String   @id @default(cuid())
  filename   String
  url        String
  mimeType   String   @map("mime_type")
  size       Int      @default(0)
  altText    String?  @map("alt_text")
  folder     String   @default("/")
  uploadedBy String?  @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([folder])
  @@map("cms_media")
}

model CmsBlog {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String    @default("")
  content     String    @default("")
  coverImage  String?   @map("cover_image")
  category    String    @default("General")
  tags        String    @default("[]")
  authorId    String?   @map("author_id")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([slug])
  @@index([category])
  @@map("cms_blogs")
}

model CmsBackground {
  id               String   @id @default(cuid())
  section          String   @unique
  bgType           String   @default("gradient") @map("bg_type")
  gradient         String?
  imageUrl         String?  @map("image_url")
  videoDesktop     String?  @map("video_desktop")
  videoTablet      String?  @map("video_tablet")
  videoMobile      String?  @map("video_mobile")
  overlayColor     String?  @map("overlay_color")
  overlayOpacity   Int      @default(0) @map("overlay_opacity")
  overlayBlendMode String?  @map("overlay_blend_mode")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("cms_backgrounds")
}

model CmsNavLink {
  id           String   @id @default(cuid())
  label        String
  href         String
  isPage       Boolean  @default(false) @map("is_page")
  mega         Boolean  @default(false)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([displayOrder])
  @@map("cms_nav_links")
}

model CmsTypography {
  id             String   @id @default(cuid())
  element        String   @unique
  fontFamily     String   @map("font_family")
  fontWeight     String   @default("400") @map("font_weight")
  fontSize       String?  @map("font_size")
  lineHeight     String?  @map("line_height")
  letterSpacing  String?  @map("letter_spacing")
  fontSource     String   @default("system") @map("font_source")
  fontFileUrl    String?  @map("font_file_url")
  fontFileFormat String?  @map("font_file_format")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("cms_typography")
}

model CmsFontPreset {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  config      String   @default("{}")
  isBuiltin   Boolean  @default(false) @map("is_builtin")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("cms_font_presets")
}

model CmsTheme {
  id         String   @id @default(cuid())
  name       String   @unique
  mode       String   @default("dark")
  primary    String   @default("#136DFF")
  accent     String   @default("#FF53A9")
  background String?
  foreground String?
  muted      String?
  border     String?
  card       String?
  config     String   @default("{}")
  isActive   Boolean  @default(false) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("cms_themes")
}

model CmsThemePreset {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  mode        String   @default("dark")
  config      String   @default("{}")
  isBuiltin   Boolean  @default(false) @map("is_builtin")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("cms_theme_presets")
}

model Lead {
  id              String    @id @default(cuid())
  name            String
  email           String
  phone           String    @default("")
  serviceInterest String?   @map("service_interest")
  message         String    @default("")
  status          String    @default("New")
  sourcePage      String?   @map("source_page")
  source          String    @default("Contact Form")
  notes           String    @default("")
  internalNotes   String    @default("") @map("internal_notes")
  assignedTo      String?   @map("assigned_to")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@index([assignedTo])
  @@map("leads")
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String   @default("info")
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([read])
  @@index([userId])
  @@map("admin_notifications")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  subject     String
  htmlContent String   @map("html_content")
  textContent String?  @map("text_content")
  variables   String   @default("[]")
  category    String   @default("general")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

model EmailWorkflow {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  trigger     String   @default("manual")
  steps       String   @default("[]")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("email_workflows")
}

model SmtpLog {
  id         String   @id @default(cuid())
  type       String   @default("dispatch")
  toEmail    String   @map("to_email")
  fromEmail  String?  @map("from_email")
  subject    String?
  templateId String?  @map("template_id")
  status     String   @default("sent")
  error      String?
  messageId  String?  @map("message_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([status])
  @@map("smtp_logs")
}

model SeoPageMeta {
  id            String   @id @default(cuid())
  path          String   @unique
  title         String?
  description   String?
  canonicalUrl  String?  @map("canonical_url")
  ogImageUrl    String?  @map("og_image_url")
  ogTitle       String?  @map("og_title")
  ogDescription String?  @map("og_description")
  twitterCard   String?  @default("summary_large_image") @map("twitter_card")
  keywords      String   @default("[]")
  noindex       Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([path])
  @@map("seo_page_meta")
}

model SeoSitemapConfig {
  id               String   @id @default(cuid())
  baseUrl          String   @default("https://www.clicktaketech.com") @map("base_url")
  includePages     Boolean  @default(true) @map("include_pages")
  includeServices  Boolean  @default(true) @map("include_services")
  includeBlogs     Boolean  @default(true) @map("include_blogs")
  includePortfolio Boolean  @default(true) @map("include_portfolio")
  changefreq       String   @default("weekly")
  priority         String   @default("0.7")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("seo_sitemap_config")
}

model SeoRobotsConfig {
  id            String   @id @default(cuid())
  userAgent     String   @default("*") @map("user_agent")
  allowAll      Boolean  @default(true) @map("allow_all")
  disallowPaths String   @default("/admin,/api") @map("disallow_paths")
  sitemapUrl    String   @default("https://www.clicktaketech.com/sitemap.xml") @map("sitemap_url")
  crawlDelay    Int?     @map("crawl_delay")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("seo_robots_config")
}

model TeamMember {
  id           String   @id @default(cuid())
  fullName     String   @map("full_name")
  roleTitle    String   @map("role_title")
  bio          String   @default("")
  linkedinUrl  String?  @map("linkedin_url")
  githubUrl    String?  @map("github_url")
  avatarUrl    String?  @map("avatar_url")
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([displayOrder])
  @@map("team_members")
}

model JobOpening {
  id           String           @id @default(cuid())
  title        String
  department   String           @default("General")
  location     String           @default("Remote")
  type         String           @default("Full-time")
  description  String           @default("")
  requirements String           @default("[]")
  salaryRange  String?          @map("salary_range")
  isActive     Boolean          @default(true) @map("is_active")
  closingDate  DateTime?        @map("closing_date")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  applications JobApplication[]

  @@index([isActive])
  @@map("job_openings")
}

model JobApplication {
  id          String     @id @default(cuid())
  jobId       String     @map("job_id")
  fullName    String     @map("full_name")
  email       String
  phone       String?
  resumeUrl   String?    @map("resume_url")
  coverLetter String?    @map("cover_letter")
  status      String     @default("Submitted")
  notes       String     @default("")
  createdAt   DateTime   @default(now()) @map("created_at")
  job         JobOpening @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([status])
  @@map("job_applications")
}

model PortfolioItem {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  client       String   @default("")
  category     String   @default("Web Development")
  industry     String   @default("")
  excerpt      String   @default("")
  description  String   @default("")
  coverImage   String?  @map("cover_image")
  gallery      String   @default("[]")
  results      String   @default("[]")
  technologies String   @default("[]")
  liveUrl      String?  @map("live_url")
  caseStudyUrl String?  @map("case_study_url")
  isFeatured   Boolean  @default(false) @map("is_featured")
  isPublished  Boolean  @default(true) @map("is_published")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isFeatured])
  @@map("portfolio_items")
}

model Testimonial {
  id            String   @id @default(cuid())
  clientName    String   @map("client_name")
  clientTitle   String?  @map("client_title")
  clientCompany String?  @map("client_company")
  avatarUrl     String?  @map("avatar_url")
  quote         String
  rating        Int      @default(5)
  serviceId     String?  @map("service_id")
  isFeatured    Boolean  @default(false) @map("is_featured")
  isPublished   Boolean  @default(true) @map("is_published")
  displayOrder  Int      @default(0) @map("display_order")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([isPublished])
  @@map("testimonials")
}

model Resource {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  type          String    @default("blog")
  excerpt       String    @default("")
  content       String    @default("")
  coverImage    String?   @map("cover_image")
  fileUrl       String?   @map("file_url")
  videoUrl      String?   @map("video_url")
  category      String    @default("General")
  tags          String    @default("[]")
  authorId      String?   @map("author_id")
  status        String    @default("Upcoming")
  isPublished   Boolean   @default(false) @map("is_published")
  publishedAt   DateTime? @map("published_at")
  downloadCount Int       @default(0) @map("download_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([type])
  @@index([isPublished])
  @@map("resources")
}

model AdminUser {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  fullName     String     @map("full_name")
  roleId       String?    @map("role_id")
  status       String     @default("Active")
  avatarUrl    String?    @map("avatar_url")
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  role         AdminRole? @relation(fields: [roleId], references: [id])

  @@index([email])
  @@map("admin_users")
}

model AdminRole {
  id          String           @id @default(cuid())
  name        String           @unique
  description String           @default("")
  color       String           @default("#136DFF")
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       AdminUser[]
  permissions RolePermission[]

  @@map("admin_roles")
}

model RolePermission {
  id            String    @id @default(cuid())
  roleId        String    @map("role_id")
  permissionKey String    @map("permission_key")
  allowed       Boolean   @default(true)
  role          AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionKey])
  @@index([roleId])
  @@map("role_permissions")
}

model SecuritySetting {
  id        String   @id @default(cuid()) @map("pk")
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("security_settings")
}

model SecurityLog {
  id        String   @id @default(cuid())
  type      String   @default("info")
  event     String
  userId    String?  @map("user_id")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  String   @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([event])
  @@index([createdAt])
  @@map("security_logs")
}

model BlockedIp {
  id        String    @id @default(cuid())
  ipAddress String    @unique @map("ip_address")
  reason    String    @default("")
  blockedBy String?   @map("blocked_by")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("blocked_ips")
}

model Backup {
  id        String   @id @default(cuid())
  filename  String
  sizeBytes Int      @map("size_bytes")
  status    String   @default("completed")
  type      String   @default("manual")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("backups")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?  @map("user_agent")
  country   String?
  city      String?
  sessionId String?  @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([path])
  @@index([createdAt])
  @@map("page_views")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  userName  String?  @map("user_name")
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  details   String   @default("{}")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SiteSetting {
  id        String   @id @default(cuid()) @map("pk")
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model Service {
  id                  String   @id @default(cuid())
  slug                String   @unique
  category            String
  categoryLabel       String?  @map("category_label")
  title               String
  description         String   @default("")
  detailedDescription String   @default("") @map("detailed_description")
  iconName            String   @default("Sparkles") @map("icon_name")
  imageUrl            String?  @map("image_url")
  gradient            String?
  glow                String?
  eyebrow             String?
  items               String   @default("[]")
  results             String   @default("[]")
  differentiators     String   @default("[]")
  deliverables        String   @default("[]")
  faq                 String   @default("[]")
  processSteps        String   @default("[]")
  pricingPackages     String   @default("[]")
  displayOrder        Int      @default(0) @map("display_order")
  isPublished         Boolean  @default(true) @map("is_published")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([displayOrder])
  @@map("services")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false) @map("published")
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("posts")
}

model ProviderConfig {
  id          String   @id @default(cuid())
  category    String
  providerId  String
  displayName String
  isActive    Boolean  @default(false) @map("is_active")
  priority    Int      @default(0)
  credentials String   @default("{}")
  config      String   @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([category, providerId])
  @@index([category, isActive, priority])
  @@map("provider_configs")
}

model ProviderHealth {
  id             String    @id @default(cuid())
  providerId     String    @unique
  category       String
  status         String    @default("healthy")
  latencyMs      Int?      @map("latency_ms")
  lastCheckedAt  DateTime  @default(now()) @map("last_checked_at")
  lastError      String?   @map("last_error")
  errorCount5min Int       @default(0) @map("error_count_5min")
  cooldownUntil  DateTime? @map("cooldown_until")

  @@index([category, status])
  @@map("provider_health")
}

model ProviderUsage {
  id         String   @id @default(cuid())
  providerId String
  category   String
  metric     String
  value      BigInt
  recordedAt DateTime @default(now()) @map("recorded_at")

  @@index([providerId, metric, recordedAt])
  @@map("provider_usage")
}

model EmailLog {
  id           String   @id @default(cuid())
  messageId    String?  @map("message_id")
  providerId   String
  toAddress    String   @map("to_address")
  subject      String
  status       String   @default("sent")
  errorMessage String?  @map("error_message")
  metadata     String   @default("{}")
  sentAt       DateTime @default(now()) @map("sent_at")

  @@index([providerId, sentAt])
  @@index([status, sentAt])
  @@map("email_logs")
}

model StorageObject {
  id              String   @id @default(cuid())
  key             String   @unique
  contentType     String   @map("content_type")
  sizeBytes       BigInt   @map("size_bytes")
  primaryProvider String   @map("primary_provider")
  replicatedTo    String   @default("[]")
  uploadedBy      String?  @map("uploaded_by")
  metadata        String   @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([primaryProvider])
  @@map("storage_objects")
}
